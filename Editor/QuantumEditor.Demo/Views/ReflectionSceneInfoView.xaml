<UserControl x:Class="QuantumEditor.Demo.Views.ReflectionSceneInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuantumEditor.Demo.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ControlStyleDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <DockPanel LastChildFill="True">
        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
            <DockPanel>
                <RichTextBox
                    IsReadOnly="True"
                    BorderThickness="0"
                    VerticalScrollBarVisibility="Disabled"
                    HorizontalScrollBarVisibility="Disabled"
                    Padding="10" DockPanel.Dock="Top">
                    <FlowDocument FontFamily="{StaticResource Global_Font}">
                        <Paragraph Foreground="{StaticResource Title_Color}" TextAlignment="Center" FontSize="40">
                            Reflection Scene
                        </Paragraph>
                        <Paragraph Margin="6 0 6 20" FontSize="25">
                            This scene showcases the engine’s reflection rendering. It contains two reflective objects alongside several standard objects such as a car, a container, and the floor. 
                            The lighting setup includes one directional light and one point light. 
                            The engine supports multiple reflection ray tracing, and this scene demonstrates up to three levels of recursive reflections.
                        </Paragraph>
                        <Paragraph Margin="6 0 6 20" FontSize="25">
                            One reflective object is a wall that uses a texture as a reflection map.
                            other is a sphere implementing simple reflection rendering.
                            In hybrid rendering mode, the reflection is implemented using G Buffer, Ray tracing and rasterization.
                        </Paragraph>
                        <Paragraph Margin="6" FontSize="30">
                            User Guide:
                        </Paragraph>
                        <Paragraph Margin="6" FontSize="25">
                            1. Hold the
                            <Bold>right mouse button</Bold> and use the
                            <Bold>W, A, S, D</Bold> keys along with mouse movement to navigate through the scene.
                        </Paragraph>
                        <Paragraph Margin="6" FontSize="25">
                            2. Use
                            <Bold>-</Bold> and
                            <Bold>+</Bold> Keys to change the sphere's reflectivity between 0 and 1
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
                <ItemsControl Margin="0 20 0 0" DockPanel.Dock="Top">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Width="800" Orientation="Horizontal"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <Border Padding="10" Margin="10" BorderThickness="2" CornerRadius="10">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="DarkGoldenrod"/>
                        </Border.BorderBrush>
                        <StackPanel HorizontalAlignment="Center" Width="350">
                            <TextBlock FontSize="25" TextAlignment="Center" Margin="5 5" FontFamily="{StaticResource Global_Font}">
                    <Run Text="Graphics API:" Foreground="Black"/>
                    <Run Text=" DirectX 12" Foreground="{StaticResource DX12_Color}"/>
                            </TextBlock>
                            <TextBlock FontSize="25" TextAlignment="Center" Margin="5 5" FontFamily="{StaticResource Global_Font}">
                    <Run Text="Render Method:" Foreground="Black"/>
                    <Run Text="Hybrid" Foreground="{StaticResource Hybrid_Color}"/>
                            </TextBlock>
                            <Button Style="{StaticResource Run_Button_Style}"
                        Click="OnReflectionHybridDX12">
                                Run
                            </Button>
                        </StackPanel>

                    </Border>
                    <Border Padding="10" Margin="10" BorderThickness="2" CornerRadius="10">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="DarkGoldenrod"/>
                        </Border.BorderBrush>
                        <StackPanel HorizontalAlignment="Center" Width="350">
                            <TextBlock FontSize="25" TextAlignment="Center" Margin="5 5" FontFamily="{StaticResource Global_Font}">
                    <Run Text="Graphics API:" Foreground="Black"/>
                    <Run Text=" DirectX 12" Foreground="{StaticResource DX12_Color}"/>
                            </TextBlock>
                            <TextBlock FontSize="25" TextAlignment="Center" Margin="5 5" FontFamily="{StaticResource Global_Font}">
                    <Run Text="Render Method:" Foreground="Black"/>
                    <Run Text="Ray Tracing" Foreground="{StaticResource RayTracing_Color}"/>
                            </TextBlock>
                            <Button Style="{StaticResource Run_Button_Style}"
                        Click="OnReflectionRayTracingDX12">
                                Run
                            </Button>
                        </StackPanel>

                    </Border>
                    <Border Padding="10" Margin="10" BorderThickness="2" CornerRadius="10">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="DarkGoldenrod"/>
                        </Border.BorderBrush>
                        <StackPanel HorizontalAlignment="Center" Width="350">
                            <TextBlock FontSize="25" TextAlignment="Center" Margin="5 5" FontFamily="{StaticResource Global_Font}">
                    <Run Text="Graphics API:" Foreground="Black"/>
                    <Run Text=" Vulkan" Foreground="{StaticResource VK_Color}"/>
                            </TextBlock>
                            <TextBlock FontSize="25" TextAlignment="Center" Margin="5 5" FontFamily="{StaticResource Global_Font}">
                    <Run Text="Render Method:" Foreground="Black"/>
                    <Run Text="Hybrid" Foreground="{StaticResource Hybrid_Color}"/>
                            </TextBlock>
                            <TextBlock FontFamily="{StaticResource Global_Font}" 
                               TextAlignment="Center" FontSize="30" Foreground="DarkSlateBlue"
                               Margin="10"
                               Text="Coming Soon"/>
                        </StackPanel>

                    </Border>
                    <Border Padding="10" Margin="10" BorderThickness="2" CornerRadius="10">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="DarkGoldenrod"/>
                        </Border.BorderBrush>
                        <StackPanel HorizontalAlignment="Center" Width="350">
                            <TextBlock FontSize="25" TextAlignment="Center" Margin="5 5" FontFamily="{StaticResource Global_Font}">
                    <Run Text="Graphics API:" Foreground="Black"/>
                    <Run Text=" Vulkan" Foreground="{StaticResource VK_Color}"/>
                            </TextBlock>
                            <TextBlock FontSize="25" TextAlignment="Center" Margin="5 5" FontFamily="{StaticResource Global_Font}">
                    <Run Text="Render Method:" Foreground="Black"/>
                    <Run Text="Ray Tracing" Foreground="{StaticResource RayTracing_Color}"/>
                            </TextBlock>
                            <TextBlock FontFamily="{StaticResource Global_Font}" 
                               TextAlignment="Center" FontSize="30" Foreground="DarkSlateBlue"
                               Margin="10"
                               Text="Coming Soon"/>
                        </StackPanel>
                    </Border>
                </ItemsControl>

            </DockPanel>

        </ScrollViewer>
    </DockPanel>

</UserControl>
