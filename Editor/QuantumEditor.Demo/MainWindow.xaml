<Window x:Class="QuantumEditor.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuantumEditor.Demo"
        xmlns:view="clr-namespace:QuantumEditor.Demo.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="720" Width="1280">
    <DockPanel>
        <StackPanel HorizontalAlignment="Center" DockPanel.Dock="Left" Width="300">
            <Button Width="100" Margin="20" Click="OnSimpleSceneClicked">
                Simple Scene
            </Button>
            <Button Width="100" Margin="20" Click="OnReflectionSceneClicked">
                Reflection Scene
            </Button>
            <Button Width="100" Margin="20" Click="OnShadowSceneClicked">
                Shadow Scene
            </Button>
        </StackPanel>
        <ContentPresenter Name="viewHost">
            
        </ContentPresenter>
    </DockPanel>
</Window>
